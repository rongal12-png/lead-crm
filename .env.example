# Database (Neon PostgreSQL recommended)
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars-here-generate-with-openssl-rand-base64-32"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# Voice commands use the browser's Web Speech API (Chrome/Edge) — no server-side transcription required.

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# App Config
NEXT_PUBLIC_APP_NAME="Lead CRM"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
